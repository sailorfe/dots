#!/usr/bin/env bash
set -euo pipefail

source "$HOME/.config/themes/init.sh"
source "$HOME/.config/wmenu/args.sh"

FOLDER="$HOME/d/flor"
TERMINAL=foot
EDITOR=nvim

open_note() {
  "${TERMINAL[@]}" -e "$EDITOR" "$1" >/dev/null 2>&1 &
  disown
}

daily() {
  open_note "$FOLDER/notes/daily/$(date -Id).md"
}

fleeting() {
  name="$(echo "" | wmenu -f 'Cozette 11' "${WMENU_ARGS[@]}" -p "filename ")" || exit 0
  [[ -z "$name" ]] && exit 0
  open_note "$FOLDER/notes/fleeting/$name.md"
}

selected() {
  choice=$(
    {
      echo "☉ open daily note"
      echo " ☽ create new note"
      find "$FOLDER" -type f -name "*.md" | sed "s|$FOLDER/||" | sort -r
    } | wmenu -l 20 -i -f 'Cozette 11' "${WMENU_ARGS[@]}" -p "notes "
  )
  case $choice in
  "☉ open daily note") daily ;;
  " ☽ create new note") fleeting ;;
  *.md) open_note "$FOLDER/$choice" ;;
  *) exit ;;
  esac
}

selected
