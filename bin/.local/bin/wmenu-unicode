#!/usr/bin/env bash
# copy a unicode character to the clipboard
set -euo pipefail

source "$HOME/.config/themes/init.sh"

WMENU_ARGS=(
  -N "$COLOR_BACKGROUND"
  -n "$COLOR_FOREGROUND"
  -S "$COLOR_BRIGHT_BLACK"
  -s "$COLOR_FOREGROUND"
  -M "$COLOR_CYAN"
  -m "$COLOR_BACKGROUND"
)

EMOJI_FILE="$HOME/.config/wmenu/emojis.txt"
GLYPH_FILE="$HOME/.config/wmenu/glyphs.txt"

CHOICE=$(cat "$GLYPH_FILE" "$EMOJI_FILE" | wmenu -l 20 -i -f 'Cozette 11' "${WMENU_ARGS[@]}" -p "unicode ")

if [ -z "$CHOICE" ]; then
  exit 1
fi

echo "$CHOICE" | awk '{print $1}' | tr -d '\n' | wl-copy

notify-send "copied to clipboard" "$(wl-paste)"
