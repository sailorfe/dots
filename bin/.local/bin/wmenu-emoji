#!/usr/bin/env bash
# copy a unicode character to the clipboard
set -euo pipefail

source "$HOME/.config/themes/init.sh"

WMENU_ARGS=(
  -l 20
  -i
  -f 'Cozette 11'
  -p "emojis "
  -N "$COLOR_BACKGROUND"
  -n "$COLOR_FOREGROUND"
  -S "$COLOR_BRIGHT_BLACK"
  -s "$COLOR_FOREGROUND"
  -M "$COLOR_CYAN"
  -m "$COLOR_BACKGROUND"
)

EMOJI_FILE="$HOME/.config/wmenu/emojis.txt"

CHOICE=$(cat "$EMOJI_FILE" | wmenu "${WMENU_ARGS[@]}")

if [ -z "$CHOICE" ]; then
  exit 1
fi

echo "$CHOICE" | awk '{print $1}' | tr -d '\n' | wl-copy

notify-send "copied to clipboard" "$(wl-paste)"
