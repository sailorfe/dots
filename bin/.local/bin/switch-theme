#!/usr/bin/env bash

render() {
  local name="$1"
  local template="$2"
  local output="$3"
  local hook="$4"

  if [ -f "$template" ]; then
    echo "switching $name..."
    envsubst <"$template" >"$output"
    [ -n "$hook" ] && eval "$hook"
  fi
}

render bemenu ~/.config/bemenu/template.sh ~/.config/bemenu/args.sh
render alacritty ~/.config/alacritty/template.toml ~/.config/alacritty/alacritty.toml
render foot ~/.config/foot/template.ini ~/.config/foot/foot.ini
render sway ~/.config/sway/template ~/.config/sway/config "command -v sway >/dev/null 2>&1 && sway & swaymsg reload"
render swaylock ~/.config/swaylock/template ~/.config/swaylock/config
render wezterm ~/.config/wezterm/template.lua ~/.config/wezterm/wezterm.lua
render mako ~/.config/mako/template ~/.config/mako/config "command -v makoctl >/dev/null 2>&1 && makoctl reload"

if command -v notify-send >/dev/null 2>&1; then
  notify-send "Switched theme" "$THEME"
else
  echo "Switched theme: $THEME"
fi
