#!/usr/bin/env bash
# elogind must be part of boot runlevel
set -euo pipefail

LOW_THRESHOLD=20
CRITICAL_THRESHOLD=5
CHECK_INTERVAL=300 # 5 minutes

while true; do
  BAT_PATH="/sys/class/power_supply/BAT0"
  BATTERY_LEVEL=$(cat "$BAT_PATH/capacity")
  STATUS=$(cat "$BAT_PATH/status")

  if [ "$STATUS" = "Discharging" ]; then

    if [ "$BATTERY_LEVEL" -le "$CRITICAL_THRESHOLD" ]; then
      notify-send -u critical "EMERGENCY" "Battery at ${BATTERY_LEVEL}%. Hibernating now..."
      sleep 2
      if rc-service elogind status >/dev/null 2>&1; then
        loginctl hibernate
      else
        doas sh -c 'echo mem > /sys/power/state'
      fi

    elif [ "$BATTERY_LEVEL" -le "$LOW_THRESHOLD" ]; then
      notify-send -u critical "Battery Low" "Level: ${BATTERY_LEVEL}%"
      sleep 2
    fi
  fi

  sleep "$CHECK_INTERVAL"
done
