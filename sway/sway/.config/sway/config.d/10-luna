# ---------------------------------------------------------------------- // luna
set $base #37273f
set $surface #422f4c
set $overlay #4d3659
set $text #dbc8e5
set $red #e25057
set $accent #a98de2
set $light #c0a7f1

# ------------------------------------------------------------------- // output

output $builtin mode 1920x1080 bg /home/sailorfe/m/img/wall/page009.jpg fill
output $tv mode 3840x2160 bg /home/sailorfe/m/img/wall/page009.jpg fill

# ---------------------------------------------------------------------- // foot

set $term foot --config ~/.config/foot/themes/luna.ini

# --------------------------------------------------------------------- // idle
exec swayidle -w \
	timeout 3000 'swaylock -f -c 2d1d35' \
  timeout 6000 'swaymsg "output * dpms off"' \
		resume 'swaymsg "output * dpms on"' \
  before-sleep 'swaylock -f -c 2d1d35'

# -------------------------------------------------------------------- // wmenu

set $menu wmenu-run -f 'Cozette 11' -l 12 \
	-N '$base' -n '$text' \
	-M '$accent' -m '$base' \
	-S '$overlay' -s '$text' \
	-p 'wmenu '

# ------------------------------------------------------------------ // windows
#												border	  bg			  fg		indicator		child_border
client.focused          $accent	  $accent	  $base $accent	    $accent
client.focused_inactive $overlay	$overlay	$text	$overlay	  $overlay
client.unfocused        $surface	$surface	$text	$surface	  $surface
client.urgent           $red	    $red	    $text	$red	      $red
client.placeholder      $base	    $base	    $text	$base	      $base
client.background       $overlay
