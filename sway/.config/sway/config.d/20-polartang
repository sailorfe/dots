# == swaybar =============================================================

bar {
	colors {
		background	$base
		statusline	$light
		separator		$overlay

#												border	bg			fg
		focused_workspace		$accent	$accent	$base
		active_workspace		$accent	$accent	$text
		inactive_workspace	$surface	$surface	$text
		urgent_workspace		$red	$red	$text
		binding_mode				$accent	$accent	$surface
	}
	position top
  status_command while ~/.config/sway/virtual.sh; do sleep 1; done
}
