font=Cozette 8

width=360
progress-color=over #362853
height=540
padding=12
margin=12
max-icon-size=70
layer=overlay

border-size=2
border-radius=0

default-timeout=10000

[urgency=low]
border-color=#291e3e
background-color=#362853
text-color=#e1d9f2

[urgency=normal]
border-color=#9470db
background-color=#b293ed
text-color=#1b1429

[urgency=high]
background-color=#d65c5c
border-color=#eb8484
text-color=#1b1429

ignore-timeout=1
