font=Cozette 8

width=360
progress-color=over #736490
height=540
padding=12
margin=12
max-icon-size=70
layer=overlay

border-size=2
border-radius=0

default-timeout=10000

[urgency=low]
background-color=#654077
border-color=#87569f
text-color=#dbc8e5

[urgency=normal]
background-color=#a98de2
border-color=#c0a7f1
text-color=#211726

[urgency=high]
background-color=#e25057
border-color=#f8777e
text-color=#211726
ignore-timeout=1
