font=Cozette 8

width=360
progress-color=over #533960
height=540
padding=12
margin=12
max-icon-size=70
layer=overlay

border-size=2
border-radius=0

default-timeout=10000

[urgency=low]
border-color=#422e4d
background-color=#533960
text-color=#ead9f2

[urgency=normal]
border-color=#b27de8
background-color=#c99df6
text-color=#2c1f33

[urgency=high]
background-color=#f07575
border-color=#fd9696
text-color=#2c1f33

ignore-timeout=1
