font=Cozette 8

width=360
progress-color=over #90647f
height=540
padding=12
margin=12
max-icon-size=70
layer=overlay

border-size=2
border-radius=0

default-timeout=10000

[urgency=normal]
background-color=#f269ad
border-color=#ff99cc
text-color=#281520

[urgency=low]
background-color=#3e1d31
border-color=#683152
text-color=#f4b9dc

[urgency=high]
background-color=#a90f30
border-color=#de3557
text-color=#f8d3e9
ignore-timeout=1
