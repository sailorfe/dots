font=Cozette 8

width=360
progress-color=over #90647f
height=540
padding=12
margin=12
max-icon-size=70
layer=overlay

border-size=2
border-radius=0

default-timeout=10000

[urgency=normal]
background-color=#e28dc0
border-color=#f47cac
text-color=#261720

[urgency=low]
background-color=#331f2b
border-color=#3f2735
text-color=#efd2e3

[urgency=high]
background-color=#d0435f
border-color=#f47c94
text-color=#261720
ignore-timeout=1
