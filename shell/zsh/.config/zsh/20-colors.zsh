# --------------------------------------------------------------- // tty colors
. $HOME/.config/zsh/${THEME}-colors

# ------------------------------------------------------------- // shell colors
theme_color() {
  local key=$1
  jq -r ".$key" "$HOME/.config/themes/${THEME}.json"
}
